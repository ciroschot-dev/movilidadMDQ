# Google Maps backend (Distance Matrix)
GOOGLE_MAPS_KEY=tu_google_maps_key

# OpenWeather
WEATHER_API_KEY=tu_openweather_key

# Base de datos AWS RDS MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://tu-endpoint-rds.amazonaws.com:3306/movilidadmdq
DB_USER=tu_usuario
DB_PASSWORD=tu_password

# JWT
JWT_SECRET=generar_con_openssl_rand_base64_32
JWT_EXPIRATION=86400000

# Google OAuth2
GOOGLE_OAUTH_CLIENT_ID=tu_client_id_de_google_console
GOOGLE_OAUTH_CLIENT_SECRET=tu_client_secret_de_google_console

# OAuth2 redirect frontend (opcional; este es el default)
app.oauth2.redirectUri=http://localhost:5173/oauth2/redirect

# CORS frontend permitido
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173